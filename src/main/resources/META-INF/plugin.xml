<idea-plugin>
  <id>com.florexlabs.docscribe</id>
  <name>DocScribe</name>
  <vendor>FlorexLabs</vendor>

  <description><![CDATA[
        <p>Auto-generate inline YARD documentation for Ruby methods using <a href="https://github.com/unurgunite/docscribe">docscribe</a>.</p>
        <h3>Features</h3>
        <ul>
            <li>Check Ruby files for missing YARD documentation</li>
            <li>Apply safe fixes (add required tags)</li>
            <li>Apply aggressive fixes (add full documentation)</li>
            <li>Inline diagnostics on file open and save</li>
            <li>Collapsible YARD comment blocks</li>
            <li>RBS type inference</li>
            <li>Rake file support</li>
        </ul>
        <p>Compatible with <strong>docscribe >= 1.5.0</strong>.</p>
    ]]></description>

  <change-notes><![CDATA[
        <h3>0.1.4</h3>
        <h4>Fixed</h4>
        <ul>
            <li>RPC protocol deadlock — JSON-RPC requests now include trailing newline and EOF signal</li>
            <li>Exit code semantics — all fix actions check <code>exitCode != 0</code> instead of <code>&gt;= 2</code></li>
            <li>VFS refresh in intention actions — ensures external file changes are detected</li>
            <li>Folding builder never loaded — <code>language="Ruby"</code> &rarr; <code>language="ruby"</code></li>
            <li>Folding regions silently dropped — added <code>order="first"</code></li>
            <li>CI test failures — added Ruby setup, docscribe gem, bundler-cache</li>
        </ul>
        <h4>Added</h4>
        <ul>
            <li>Daemon mode — persistent Ruby server over Unix socket JSON-RPC 2.0</li>
            <li><code>hideCommentsByDefault</code> reactivity — folding rebuilds on setting toggle</li>
            <li>Full KDoc documentation on all 17 main source files</li>
            <li>45 new tests (117 total)</li>
        </ul>
        <h4>Changed</h4>
        <ul>
            <li>Removed 5 dead settings (<code>commandPath</code>, <code>useBundleExec</code>, <code>runOnSave</code>, <code>useRbs</code>, <code>useDaemon</code>)</li>
            <li>Settings page reduced to a single checkbox</li>
            <li>Always passes <code>-B</code> flag in safe/aggressive modes</li>
            <li>Daemon always-on — no toggle</li>
        </ul>
    ]]></change-notes>

  <version>0.1.4</version>
  <idea-version since-build="261" until-build="261.*"/>

  <depends>com.intellij.modules.platform</depends>
  <depends>com.intellij.modules.ruby</depends>

  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceImplementation="com.florexlabs.docscribe.settings.DocscribeSettings"/>
    <applicationService serviceImplementation="com.florexlabs.docscribe.annotator.DocscribeAnnotatorCache"/>
    <applicationService serviceImplementation="com.florexlabs.docscribe.settings.DocscribeSettingsChangeListenerImpl"/>
    <projectService serviceImplementation="com.florexlabs.docscribe.runner.DocscribeDaemon"/>

    <notificationGroup id="DocScribe" displayType="BALLOON" key="DocScribe notifications"/>

    <externalAnnotator language="Ruby"
                       implementationClass="com.florexlabs.docscribe.annotator.DocscribeAnnotator"/>

    <applicationConfigurable
      groupId="tools"
      displayName="DocScribe"
      id="com.florexlabs.docscribe.settings"
      instance="com.florexlabs.docscribe.settings.DocscribeSettingsConfigurable"/>

    <lang.foldingBuilder language="ruby" order="first"
                         implementationClass="com.florexlabs.docscribe.folding.YardFoldingBuilder"/>

    <dependencySupport kind="ruby" coordinate="docscribe" displayName="docscribe gem"/>
    <dependencySupport kind="ruby" coordinate="rbs" displayName="RBS"/>

    <intentionAction>
      <className>com.florexlabs.docscribe.annotator.DocscribeFixIntention</className>
      <category>DocScribe</category>
    </intentionAction>
    <intentionAction>
      <className>com.florexlabs.docscribe.annotator.DocscribeAggressiveFixIntention</className>
      <category>DocScribe</category>
    </intentionAction>
    <intentionAction>
      <className>com.florexlabs.docscribe.annotator.DocscribeCheckIntention</className>
      <category>DocScribe</category>
    </intentionAction>
  </extensions>

  <actions>
    <action id="com.florexlabs.docscribe.CheckFileAction"
            class="com.florexlabs.docscribe.actions.CheckFileAction"
            text="Check Current File"
            description="Run docscribe check on the current Ruby file">
      <keyboard-shortcut keymap="$default"
                         first-keystroke="ctrl shift D"
                         second-keystroke="C"/>
    </action>

    <action id="com.florexlabs.docscribe.CheckWorkspaceAction"
            class="com.florexlabs.docscribe.actions.CheckWorkspaceAction"
            text="Check Entire Workspace"
            description="Run docscribe check on all Ruby files in the project">
      <keyboard-shortcut keymap="$default"
                         first-keystroke="ctrl shift D"
                         second-keystroke="W"/>
    </action>

    <action id="com.florexlabs.docscribe.SafeFixAction"
            class="com.florexlabs.docscribe.actions.SafeFixAction"
            text="Apply Safe Fixes"
            description="Apply docscribe safe fixes to current file">
      <keyboard-shortcut keymap="$default"
                         first-keystroke="ctrl shift D"
                         second-keystroke="S"/>
    </action>

    <action id="com.florexlabs.docscribe.AggressiveFixAction"
            class="com.florexlabs.docscribe.actions.AggressiveFixAction"
            text="Apply Aggressive Fixes"
            description="Apply docscribe aggressive fixes to current file">
      <keyboard-shortcut keymap="$default"
                         first-keystroke="ctrl shift D"
                         second-keystroke="A"/>
    </action>

    <action id="com.florexlabs.docscribe.UpdateTypesAction"
            class="com.florexlabs.docscribe.actions.UpdateTypesAction"
            text="Update Types from RBS"
            description="Run docscribe update_types to refresh YARD docs from RBS signatures"/>

    <group id="com.florexlabs.docscribe.DocScribeGroup"
           text="DocScribe" popup="true"
           icon="/com/florexlabs/docscribe/icons/docscribe.png">
      <add-to-group group-id="EditorPopupMenu"
                    anchor="first"/>
      <reference ref="com.florexlabs.docscribe.CheckFileAction"/>
      <reference ref="com.florexlabs.docscribe.SafeFixAction"/>
      <reference ref="com.florexlabs.docscribe.AggressiveFixAction"/>
      <separator/>
      <reference ref="com.florexlabs.docscribe.CheckWorkspaceAction"/>
      <reference ref="com.florexlabs.docscribe.UpdateTypesAction"/>
    </group>
  </actions>
</idea-plugin>
